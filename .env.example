GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OCR_MODEL=gemini-1.5-flash

LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT="agents-repo"
LANGCHAIN_TRACING_V2=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com # Optional, defaults to hosted LangSmith

# ZOA & OCR MCP
ZOA_MCP_URL=http://mock-mcp:8080
OCR_MCP_URL=http://mock-ocr:8080

# DB (Cloud SQL)
USE_CLOUD_SQL=false
INSTANCE_CONNECTION_NAME=project:region:instance
DB_USER=postgres
DB_PASS=password
DB_NAME=zoa_agents
DB_PRIVATE_IP=true